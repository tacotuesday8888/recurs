{
  "name": "recurs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "recurs": "packages/cli/dist/main.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "npm run check:generated && npm run lint && npm run typecheck && npm test && npm run build",
    "check:generated": "node scripts/generate-non-secret-policy.mjs --check",
    "check:native": "npm run check:generated && npm run native:test && npm run native:build && npm run native:lint-resources && npm run native:smoke",
    "generate:non-secret-policy": "node scripts/generate-non-secret-policy.mjs",
    "typecheck": "tsc -b --pretty false && npm run typecheck:contract-tests",
    "typecheck:contract-tests": "tsc -p packages/contracts/tsconfig.type-tests.json --pretty false",
    "lint": "eslint .",
    "native:build": "swift build --package-path native/macos",
    "native:lint-resources": "plutil -lint native/macos/Resources/*.plist native/macos/Resources/*.entitlements",
    "native:smoke": "node scripts/check-native-source-launcher.mjs",
    "native:test": "swift test --package-path native/macos",
    "test": "vitest run",
    "recurs": "node packages/cli/dist/main.js"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.1",
    "eslint": "10.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
