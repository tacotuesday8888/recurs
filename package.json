{
  "name": "recurs",
  "version": "0.1.0-alpha.1",
  "description": "A coding-agent harness with durable, bounded team orchestration",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "recurs": "dist/cli/main.js"
  },
  "files": [
    "dist/cli/main.js",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tacotuesday8888/recurs.git"
  },
  "bugs": {
    "url": "https://github.com/tacotuesday8888/recurs/issues"
  },
  "homepage": "https://github.com/tacotuesday8888/recurs#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "keywords": [
    "agent",
    "cli",
    "coding-agent",
    "llm",
    "subagents"
  ],
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "tsc -b && npm run package:build",
    "check": "npm run check:generated && npm run lint && npm run typecheck && npm test && npm run build && npm run package:check",
    "check:generated": "node scripts/generate-non-secret-policy.mjs --check && node scripts/generate-provider-activation-profiles.mjs --check && node scripts/generate-recurs-brand.mjs --check",
    "generate:non-secret-policy": "node scripts/generate-non-secret-policy.mjs",
    "generate:provider-activation-profiles": "node scripts/generate-provider-activation-profiles.mjs",
    "generate:recurs-brand": "node scripts/generate-recurs-brand.mjs",
    "eval:company": "npm run build --silent && node scripts/evaluate-company.mjs",
    "typecheck": "tsc -b --pretty false && npm run typecheck:contract-tests",
    "typecheck:contract-tests": "tsc -p packages/contracts/tsconfig.type-tests.json --pretty false",
    "lint": "eslint .",
    "package:build": "node scripts/build-npm-package.mjs",
    "package:check": "node --test scripts/check-ci-contract.test.mjs scripts/check-npm-release.test.mjs scripts/evaluate-company.test.mjs scripts/render-install-assets.test.mjs && node scripts/check-npm-release.mjs --check-state && node scripts/check-npm-package.mjs",
    "package:smoke-install": "node scripts/smoke-install-npm-package.mjs",
    "package:smoke-install-bun": "node scripts/smoke-install-bun-package.mjs",
    "prepack": "npm run package:build && npm run package:check",
    "test": "vitest run",
    "recurs": "node dist/cli/main.js"
  },
  "dependencies": {
    "@agentclientprotocol/codex-acp": "1.1.2",
    "@agentclientprotocol/sdk": "1.2.1",
    "@openai/codex": "0.145.0",
    "typescript": "6.0.3",
    "ws": "8.21.1",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.1",
    "@types/ws": "8.18.1",
    "eslint": "10.6.0",
    "rolldown": "1.1.5",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "optionalDependencies": {
    "@lydell/node-pty": "1.1.0"
  }
}
